# Backend
JWT_SECRET=
ENCRYPTION_KEY=
PORT=8080
DB_FILE_PATH=./backend/devshare.db
ADMIN_INIT_TOKEN=
TEMPLATE_STORAGE_PATH=./template_storage
ENV_EXECUTION_PATH=./env_executions
TF_PLUGIN_CACHE_DIR=

# Frontend (local dev only — Docker uses nginx proxy with relative URLs)
VITE_API_BASE_URL=http://localhost:8080

# Docker
APP_PORT=3000

# --- Cloud Secret Manager (optional — fetches JWT_SECRET + ENCRYPTION_KEY from a cloud vault) ---
# Set ONE of these BEFORE running ./setup.sh (not via .env — these are host-side).
# setup.sh will invoke scripts/fetch-secrets.sh on the host, write the secrets to a
# tmpfs path, and bind-mount them into the container at /run/secrets/* (read via
# the *_FILE env convention). Secrets never appear in the container env var list.
# Requires the corresponding cloud CLI installed on the host (aws / az / gcloud).
# AWS_SECRET_ID=devshare/app-secrets
# AZURE_KEYVAULT_NAME=my-devshare-vault
# GCP_SECRET_NAME=devshare-secrets

# --- Cloud Provider Credentials (for Terraform in Docker) ---
# Uncomment and set the variables for your cloud provider(s).
# These are passed into the Docker container for Terraform to use.
# See docker-compose.override.example.yml for volume mount alternatives.

# AWS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=

# GCP
# GOOGLE_APPLICATION_CREDENTIALS=/root/.config/gcloud/application_default_credentials.json
# GOOGLE_PROJECT=

# Azure (Terraform AzureRM provider uses ARM_ prefix)
# ARM_CLIENT_ID=
# ARM_CLIENT_SECRET=
# ARM_TENANT_ID=
# ARM_SUBSCRIPTION_ID=
