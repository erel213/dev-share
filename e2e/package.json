{
  "name": "dev-share-e2e",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "docs:capture": "playwright test --config=playwright.docs.config.ts",
    "docs:capture:pages": "playwright test --config=playwright.docs.config.ts --grep '@docs pages'",
    "docs:capture:debug": "playwright test --config=playwright.docs.config.ts --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
